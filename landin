    <script>
        // --- DEMO MODAL FUNCTIONS ---
        function openDemo(event) {
            event.preventDefault();
            document.getElementById('demoModal').style.display = 'block';
        }

        function closeDemo() {
            document.getElementById('demoModal').style.display = 'none';
        }

        window.onclick = function(event) {
            const modal = document.getElementById('demoModal');
            if (event.target == modal) {
                modal.style.display = 'none';
            }
        }

        // --- 1. NEURAL PARTICLE BACKGROUND ---
        const canvas = document.getElementById('neural-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.onresize = resizeCanvas;
        resizeCanvas();

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 0.4;
                this.vy = (Math.random() - 0.5) * 0.4;
            }
            update() {
                this.x += this.vx; this.y += this.vy;
                if(this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if(this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
        }

        for(let i=0; i<80; i++) particles.push(new Particle());

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.strokeStyle = "rgba(0, 122, 255, 0.15)";
            ctx.lineWidth = 0.5;

            particles.forEach((p, i) => {
                p.update();
                for(let j=i+1; j<particles.length; j++) {
                    let d = Math.hypot(p.x - particles[j].x, p.y - particles[j].y);
                    if(d < 180) {
                        ctx.beginPath(); ctx.moveTo(p.x, p.y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            });
            requestAnimationFrame(animateParticles);
        }
        animateParticles();

        // --- 2. 3D TRAFFIC LIGHT ANIMATION ---
        const lights = ['red', 'yellow', 'green'];
        let activeIndex = 2; // Start with green

        function updateTrafficLights() {
            lights.forEach(color => {
                document.getElementById(`light-${color}`).className = `light-unit ${color}`;
            });
            
            const currentColor = lights[activeIndex];
            document.getElementById(`light-${currentColor}`).classList.add(`active-${currentColor}`);
            
            // Cycle: Green (5s) -> Yellow (1.5s) -> Red (5s) -> Yellow (1.5s)
            let delay = 5000;
            if(currentColor === 'yellow') delay = 1500;

            activeIndex = (activeIndex + 1) % lights.length;
            setTimeout(updateTrafficLights, delay);
        }
        updateTrafficLights();

        // --- 3. COUNT-UP STATS ANIMATION ---
        const countUpObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    const target = parseInt(entry.target.getAttribute('data-target'));
                    let current = 0;
                    const increment = target / 50;
                    const timer = setInterval(() => {
                        current += increment;
                        entry.target.innerText = Math.floor(current);
                        if(current >= target) {
                            entry.target.innerText = target;
                            clearInterval(timer);
                        }
                    }, 30);
                    countUpObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('.count-up').forEach(c => countUpObserver.observe(c));

        // --- 4. SCROLL REVEAL (Simple Vanilla) ---
        window.addEventListener('scroll', () => {
            const reveals = document.querySelectorAll('.process-card, .feature-item');
            reveals.forEach(rev => {
                const windowHeight = window.innerHeight;
                const revealTop = rev.getBoundingClientRect().top;
                if(revealTop < windowHeight - 150) {
                    rev.style.opacity = '1';
                    rev.style.transform = 'translateY(0)';
                }
            });
        });
        
        // Init styles for reveal
        document.querySelectorAll('.process-card, .feature-item').forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(30px)';
            el.style.transition = '0.8s ease-out';
        });

    </script>
