<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TrafficFlow AI | Smart Neural City Infrastructure</title>
    
    <!-- External Resources -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;400;600;800&family=Space+Grotesk:wght@300;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* 
        ------------------------------------------------------------------
        1. CSS VARIABLES & CORE SYSTEM
        ------------------------------------------------------------------
        */
        :root {
            --primary-blue: #007aff;
            --secondary-blue: #0ea5e9;
            --soft-blue: #f0f9ff;
            --vibrant-blue: #38bdf8;
            --traffic-green: #22c55e;
            --traffic-yellow: #eab308;
            --traffic-red: #ef4444;
            --dark-navy: #0f172a;
            --text-main: #1e293b;
            --text-light: #64748b;
            --font-head: 'Space Grotesk', sans-serif;
            --font-body: 'Outfit', sans-serif;
            --glass: rgba(255, 255, 255, 0.85);
            --shadow-pro: 0 20px 50px rgba(0, 122, 255, 0.1);
        }

        /* 
        ------------------------------------------------------------------
        2. GLOBAL STYLES & ANIMATIONS
        ------------------------------------------------------------------
        */
        * {
            margin: 0; padding: 0; box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
        }

        html { scroll-behavior: smooth; overflow-x: hidden; }

        body {
            font-family: var(--font-body);
            background-color: #fff;
            color: var(--text-main);
            line-height: 1.6;
        }

        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--soft-blue); }
        ::-webkit-scrollbar-thumb { background: var(--primary-blue); border-radius: 10px; }

        @keyframes float { 0%, 100% { transform: translateY(0) rotate(0); } 50% { transform: translateY(-20px) rotate(5deg); } }
        @keyframes drift { from { transform: translateX(-10%); } to { transform: translateX(110%); } }
        @keyframes pulse-glow { 0% { box-shadow: 0 0 0 0 rgba(0, 122, 255, 0.4); } 70% { box-shadow: 0 0 0 20px rgba(0, 122, 255, 0); } 100% { box-shadow: 0 0 0 0 rgba(0, 122, 255, 0); } }

        /* 
        ------------------------------------------------------------------
        3. BACKGROUND & DECORATIVE ELEMENTS
        ------------------------------------------------------------------
        */
        #neural-canvas {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1; opacity: 0.3;
        }

        .cloud-container { position: absolute; width: 100%; height: 100%; top: 0; left: 0; pointer-events: none; overflow: hidden; z-index: 1; }
        .cloud { position: absolute; color: white; opacity: 0.6; animation: drift 30s linear infinite; }

        /* 
        ------------------------------------------------------------------
        4. NAVIGATION SYSTEM - UPDATED
        ------------------------------------------------------------------
        */
        nav {
            position: sticky; top: 0; width: 100%; padding: 16px 8%;
            display: flex; justify-content: space-between; align-items: center;
            background: #f0f9ff;
            border-bottom: 1px solid #bfdbfe;
            z-index: 1000;
        }

        .logo {
            font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 700;
            color: #1e40af; text-decoration: none;
            display: flex; align-items: center; gap: 0; letter-spacing: -0.5px;
        }
        .logo i { display: none; }

        .nav-links { display: flex; gap: 45px; list-style: none; }
        .nav-links a {
            text-decoration: none; color: #1e40af; font-weight: 500;
            font-size: 14px; transition: 0.3s; position: relative;
            font-family: 'Inter', sans-serif;
        }
        .nav-links a::after {
            content: ''; position: absolute; bottom: -5px; left: 0; width: 0;
            height: 2px; background: #0ea5e9; transition: 0.3s;
        }
        .nav-links a:hover { color: #0ea5e9; }
        .nav-links a:hover::after { width: 100%; }

        .btn-launch {
            background: #0ea5e9; color: white; padding: 10px 28px;
            border-radius: 6px; font-weight: 600; text-decoration: none;
            box-shadow: 0 4px 15px rgba(14, 165, 233, 0.15);
            transition: 0.3s; border: none; font-family: 'Inter', sans-serif;
            font-size: 13px;
        }
        .btn-launch:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(14, 165, 233, 0.25);
            background: #1e40af;
        }

        /* 
        ------------------------------------------------------------------
        5. HERO SECTION
        ------------------------------------------------------------------
        */
        .hero {
            position: relative; min-height: 95vh; padding: 120px 8% 100px;
            display: flex; align-items: center;
            background: radial-gradient(circle at 90% 10%, var(--soft-blue) 0%, #fff 60%);
            overflow: hidden;
        }

        .hero-content { flex: 1.2; z-index: 10; }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 10px;
            background: white; padding: 10px 20px; border-radius: 100px;
            color: var(--primary-blue); font-weight: 800; font-size: 12px;
            text-transform: uppercase; letter-spacing: 2px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05); margin-bottom: 30px;
            border: 1px solid var(--soft-blue);
        }

        .hero-content h1 {
            font-family: var(--font-head); font-size: clamp(45px, 7vw, 95px);
            font-weight: 700; line-height: 0.95; color: var(--dark-navy);
            margin-bottom: 30px; letter-spacing: -2px;
        }
        .hero-content h1 span {
            color: var(--primary-blue); -webkit-text-stroke: 1.5px var(--primary-blue);
            color: transparent; position: relative;
        }

        .hero-content p {
            font-size: 22px; color: var(--text-light); max-width: 650px;
            line-height: 1.6; margin-bottom: 50px;
        }

        .hero-visual { flex: 0.8; position: relative; display: flex; justify-content: center; z-index: 10; }

        /* TRAFFIC LIGHT 3D MODULE */
        .traffic-box {
            background: #1e293b; padding: 30px; border-radius: 45px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.25);
            animation: float 6s ease-in-out infinite; border: 4px solid #334155;
        }
        .light-unit {
            width: 80px; height: 80px; border-radius: 50%; margin-bottom: 25px;
            border: 6px solid rgba(0,0,0,0.2); opacity: 0.15; transition: 0.5s;
        }
        .light-unit:last-child { margin-bottom: 0; }
        .light-unit.red { background: var(--traffic-red); }
        .light-unit.yellow { background: var(--traffic-yellow); }
        .light-unit.green { background: var(--traffic-green); }

        .active-red { opacity: 1; box-shadow: 0 0 50px var(--traffic-red); }
        .active-yellow { opacity: 1; box-shadow: 0 0 50px var(--traffic-yellow); }
        .active-green { opacity: 1; box-shadow: 0 0 50px var(--traffic-green); }

        /* Floating Decorations */
        .float-deco { position: absolute; font-size: 60px; filter: drop-shadow(0 20px 20px rgba(0,0,0,0.1)); z-index: 5; }

        /* 
        ------------------------------------------------------------------
        6. TECH MARQUEE
        ------------------------------------------------------------------
        */
        .marquee-section { background: var(--dark-navy); padding: 40px 0; overflow: hidden; border-y: 1px solid rgba(255,255,255,0.1); }
        .marquee-container { display: flex; gap: 80px; animation: marquee-scroll 30s linear infinite; width: max-content; }
        .marquee-item {
            color: white; font-family: var(--font-head); font-weight: 700;
            font-size: 24px; text-transform: uppercase; letter-spacing: 4px;
            display: flex; align-items: center; gap: 15px; opacity: 0.6;
        }
        @keyframes marquee-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

        /* 
        ------------------------------------------------------------------
        7. STATS & NUMBERS
        ------------------------------------------------------------------
        */
        .stats-grid {
            padding: 120px 8%; display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px;
            background: white; position: relative;
        }
        .stat-card {
            text-align: center; padding: 40px 20px; background: var(--soft-blue);
            border-radius: 35px; border: 2px solid transparent; transition: 0.4s;
        }
        .stat-card:hover { border-color: var(--primary-blue); background: white; transform: translateY(-10px); box-shadow: var(--shadow-pro); }
        .stat-card h2 { font-family: var(--font-head); font-size: 60px; color: var(--primary-blue); font-weight: 700; margin-bottom: 10px; }
        .stat-card p { font-size: 14px; font-weight: 800; color: var(--text-light); text-transform: uppercase; letter-spacing: 2px; }

        /* 
        ------------------------------------------------------------------
        8. PROCESS MODULE (HOW IT WORKS)
        ------------------------------------------------------------------
        */
        .process-section { padding: 150px 8%; background: var(--soft-blue); position: relative; }
        .process-header { text-align: center; margin-bottom: 80px; }
        .process-header h2 { font-family: var(--font-head); font-size: 50px; color: var(--dark-navy); margin-bottom: 20px; }
        .process-header p { font-size: 18px; color: var(--text-light); max-width: 600px; margin: 0 auto; }

        .process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; position: relative; }
        .process-grid::after {
            content: ''; position: absolute; top: 40px; left: 10%; width: 80%; height: 2px;
            background: dashed var(--primary-blue); border: 2px dashed var(--vibrant-blue); opacity: 0.2; z-index: 1;
        }

        .process-card {
            background: white; padding: 40px 30px; border-radius: 40px; text-align: center;
            position: relative; z-index: 2; transition: 0.5s; border: 1px solid rgba(0,0,0,0.05);
        }
        .process-card:hover { transform: translateY(-15px); background: var(--primary-blue); color: white; }
        .process-card:hover .step-num { background: white; color: var(--primary-blue); }
        .process-card:hover p { color: rgba(255,255,255,0.8); }

        .step-num {
            width: 60px; height: 60px; background: var(--primary-blue); color: white;
            border-radius: 20px; display: flex; align-items: center; justify-content: center;
            font-size: 24px; font-weight: 800; margin: 0 auto 30px; transition: 0.3s;
        }
        .process-card h3 { font-family: var(--font-head); font-size: 22px; margin-bottom: 15px; }
        .process-card p { font-size: 15px; color: var(--text-light); transition: 0.3s; }

        /* 
        ------------------------------------------------------------------
        9. FEATURES MATRIX
        ------------------------------------------------------------------
        */
        .features-section { padding: 150px 8%; background: white; }
        .feature-item { display: flex; align-items: center; gap: 80px; margin-bottom: 120px; }
        .feature-item:nth-child(even) { flex-direction: row-reverse; }
        .feature-item:last-child { margin-bottom: 0; }

        .feature-info { flex: 1; }
        .feature-info h3 { font-family: var(--font-head); font-size: 42px; color: var(--dark-navy); margin-bottom: 25px; }
        .feature-info p { font-size: 18px; color: var(--text-light); margin-bottom: 35px; }

        .feature-visual {
            flex: 1; height: 450px; background: var(--soft-blue); border-radius: 50px;
            position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;
            box-shadow: var(--shadow-pro); border: 2px solid var(--soft-blue);
        }
        .feature-visual img { width: 90%; border-radius: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

        /* 
        ------------------------------------------------------------------
        10. FOOTER & CITY ANIMATION
        ------------------------------------------------------------------
        */
        .city-footer-anim {
            height: 180px; background: #e2e8f0; position: relative; overflow: hidden;
            border-top: 6px solid var(--text-light);
        }
        .city-car { position: absolute; bottom: 20px; font-size: 45px; animation: city-drive 15s linear infinite; }
        @keyframes city-drive { from { left: -100px; } to { left: 100vw; } }

        footer { padding: 100px 8% 50px; background: var(--dark-navy); color: white; }
        .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 80px; }
        .footer-logo h2 { font-family: var(--font-head); font-size: 32px; color: white; margin-bottom: 25px; }
        .footer-logo p { color: rgba(255,255,255,0.6); line-height: 1.8; }
        
        .footer-links h4 { font-family: var(--font-head); font-size: 18px; margin-bottom: 25px; text-transform: uppercase; letter-spacing: 2px; color: var(--primary-blue); }
        .footer-links ul { list-style: none; }
        .footer-links li { margin-bottom: 15px; }
        .footer-links a { text-decoration: none; color: rgba(255,255,255,0.7); transition: 0.3s; }
        .footer-links a:hover { color: var(--primary-blue); padding-left: 8px; }

        .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 40px; text-align: center; }
        .footer-bottom p { font-size: 13px; color: rgba(255,255,255,0.4); letter-spacing: 2px; }

        /* 
        ------------------------------------------------------------------
        12. DEMO MODAL
        ------------------------------------------------------------------
        */
        .modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            animation: fadeIn 0.3s;
        }

        .modal-content {
            background-color: white;
            margin: 50% auto;
            transform: translateY(-50%);
            padding: 0;
            border-radius: 20px;
            width: 85%;
            max-width: 500px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        .modal-header {
            background: linear-gradient(135deg, #0ea5e9 0%, #1e40af 100%);
            color: white;
            padding: 20px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h2 {
            margin: 0;
            font-family: var(--font-head);
            font-size: 22px;
        }

        .close-modal {
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            background: none;
            border: none;
            color: white;
        }

        .close-modal:hover {
            opacity: 0.8;
        }

        .modal-body {
            padding: 25px;
        }

        .video-placeholder {
            width: 100%;
            height: 200px;
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 15px;
            margin-bottom: 20px;
        }

        .video-placeholder i {
            font-size: 60px;
            color: #0ea5e9;
        }

        .video-placeholder p {
            font-size: 14px;
            color: #1e40af;
            font-weight: 600;
            margin: 0;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* 
        ------------------------------------------------------------------
        11. MOBILE RESPONSIVENESS
        ------------------------------------------------------------------
        */
        @media (max-width: 1024px) {
            .hero { flex-direction: column; text-align: center; padding-top: 150px; }
            .hero-visual { margin-top: 80px; }
            .stats-grid, .process-grid, .footer-grid { grid-template-columns: repeat(2, 1fr); }
            .feature-item, .feature-item:nth-child(even) { flex-direction: column; gap: 40px; }
        }

        @media (max-width: 640px) {
            .stats-grid, .process-grid, .footer-grid { grid-template-columns: 1fr; }
            .hero-content h1 { font-size: 45px; }
            nav { padding: 12px 5%; }
            .nav-links { display: none; }
        }
    </style>
</head>
